{
  "OpenWM": {
    "DefaultLayout": "Dwindle",
    "Gaps": 8,
    "WorkspaceCount": 9,
    "MasterRatio": 0.55,
    "PollIntervalMs": 120,
    "VirtualDesktop": {
      "Enabled": true,
      "Name": "OpenWM Desktop",
      "LaunchStartupCommands": false,
      "StartupCommands": [
        "wt.exe"
      ]
    },
    "FloatClasses": [
      "#32770",
      "OperationStatusWindow"
    ],
    "Hotkeys": [
      { "Chord": "Win+Ctrl+Q", "Action": "quit" },
      { "Chord": "Win+Ctrl+F", "Action": "toggle-floating" },
      { "Chord": "Win+Ctrl+Space", "Action": "toggle-fullscreen" },
      { "Chord": "Win+Ctrl+T", "Action": "retile" },
      { "Chord": "Win+Ctrl+L", "Action": "cycle-layout" },
      { "Chord": "Win+Ctrl+W", "Action": "close-focused" },
      { "Chord": "Win+Ctrl+M", "Action": "promote-master" },
      { "Chord": "Win+Ctrl+Left", "Action": "focus-prev" },
      { "Chord": "Win+Ctrl+Right", "Action": "focus-next" },
      { "Chord": "Win+Ctrl+PageUp", "Action": "ws-prev" },
      { "Chord": "Win+Ctrl+PageDown", "Action": "ws-next" },
      { "Chord": "Win+Ctrl+1", "Action": "ws-1" },
      { "Chord": "Win+Ctrl+2", "Action": "ws-2" },
      { "Chord": "Win+Ctrl+3", "Action": "ws-3" },
      { "Chord": "Win+Ctrl+4", "Action": "ws-4" },
      { "Chord": "Win+Ctrl+5", "Action": "ws-5" },
      { "Chord": "Win+Ctrl+6", "Action": "ws-6" },
      { "Chord": "Win+Ctrl+7", "Action": "ws-7" },
      { "Chord": "Win+Ctrl+8", "Action": "ws-8" },
      { "Chord": "Win+Ctrl+9", "Action": "ws-9" },
      { "Chord": "Win+Ctrl+Shift+1", "Action": "move-ws-1" },
      { "Chord": "Win+Ctrl+Shift+2", "Action": "move-ws-2" },
      { "Chord": "Win+Ctrl+Shift+3", "Action": "move-ws-3" },
      { "Chord": "Win+Ctrl+Shift+4", "Action": "move-ws-4" },
      { "Chord": "Win+Ctrl+Shift+5", "Action": "move-ws-5" },
      { "Chord": "Win+Ctrl+Shift+6", "Action": "move-ws-6" },
      { "Chord": "Win+Ctrl+Shift+7", "Action": "move-ws-7" },
      { "Chord": "Win+Ctrl+Shift+8", "Action": "move-ws-8" },
      { "Chord": "Win+Ctrl+Shift+9", "Action": "move-ws-9" }
    ]
  }
}
